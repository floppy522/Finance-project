{$MONEYFLOW_DOMAIN} {
    @login path /login
    log_skip @login

    log {
        output file /var/log/caddy/access.log
        format filter {
            wrap json
            request>headers>X-Telegram-Bot-Api-Secret-Token delete
            request>headers>Referer delete
            request>uri query {
                delete token
            }
        }
    }

    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer"
        Content-Security-Policy "default-src 'self'; connect-src 'self'; img-src 'self' data:; style-src 'self'; script-src 'self'; base-uri 'self'; form-action 'self'; frame-ancestors 'none'"
    }

    @api path /api/* /telegram/* /health
    handle @api {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy web:80
    }
}
